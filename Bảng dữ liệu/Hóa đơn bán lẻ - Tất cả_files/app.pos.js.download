var ePos = {
	initNavigations: function () {
		!function () {
			var e = "nav-item-open", t = "nav-item-submenu", o = "nav-group-sub";

			// helper check modifier
			function shouldPrevent(event) {
				return !(event.metaKey || event.ctrlKey);
			}

			document.querySelectorAll(".nav-vertical:not(.nav-scrollspy)").forEach((function (n) {
				n.querySelectorAll(`.${ t } > .nav-link:not(.disabled)`).forEach((function (n) {
					n.addEventListener("click", (function (c) {
						console.warn('n.addEventListener')
						// Chỉ ngăn default nếu không phải ctrl/cmd+click
						if (shouldPrevent(c)) {
							c.preventDefault();
						}
						const i = n.closest(`.${ t }`);
						const child = n.closest(`.${ t }`).querySelector(`:scope > .${ o }`);

						let nextSibling = this.nextElementSibling;

						const parLi = this.parentNode;
						if (parLi.tagName === 'LI') {
							const spanSiblings = parLi.parentNode.querySelectorAll(":scope > .nav-item-submenu > ul");
							spanSiblings.forEach((function (o) {
								if (o !== nextSibling) {
									o.classList.remove('show')
								}
							}))
						}

						const ckElse = "accordion" === n.closest(".nav-vertical").getAttribute("data-nav-type");
						if (i.classList.contains(e)) {
							i.classList.remove(e);
							child.classList.remove('show');
						} else if (ckElse) {
							i.classList.add(e);
							child.classList.add('show');

							for (let t of n.parentNode.parentNode.children) {
								if (t !== n.parentNode && t.classList.contains(e)) {
									t.querySelectorAll(`:scope > .${ o }`).forEach((function (o) {
										t.classList.remove(e)
									}))
								}
							}
						}
					}))
				}))
			}))

			document.querySelectorAll(".nav-signle").forEach((function (n) {
				n.addEventListener("click", (function (c) {
					// Chỉ ngăn default nếu không phải ctrl/cmd+click
					if (shouldPrevent(c)) {
						c.preventDefault();
					}
					if (this.parentNode.tagName === 'LI') {
						this.parentNode.parentNode.querySelectorAll(":scope > .nav-item-submenu").forEach((function (o) {
							o.classList.remove('nav-item-open')

							o.querySelectorAll(".posColl").forEach((function (o) {
								o.classList.remove('show')
							}))
						}))
					}
				}))
			}))
		}()
	}
};
coreTN = () => ePos.initNavigations();

(function() {
	let devtools = function() {};
	let isOpen = false;
	let orientation = undefined;

	const threshold = 160;

	const emitEvent = (isOpen, orientation) => {
		window.dispatchEvent(new CustomEvent('devtoolschange', {
			detail: {
				isOpen,
				orientation
			}
		}));
	};

	setInterval(function() {
		const widthThreshold = window.outerWidth - window.innerWidth > threshold;
		const heightThreshold = window.outerHeight - window.innerHeight > threshold;
		const orientation = widthThreshold ? 'vertical' : 'horizontal';

		if (
		  !(heightThreshold && widthThreshold) &&
		  ((window.Firebug && window.Firebug.chrome && window.Firebug.chrome.isInitialized) || widthThreshold || heightThreshold)
		) {
			if (!isOpen || orientation !== devtools.orientation) {
				emitEvent(true, orientation);
			}

			isOpen = true;
			devtools.orientation = orientation;
		} else {
			if (isOpen) {
				emitEvent(false, undefined);
			}

			isOpen = false;
			devtools.orientation = undefined;
		}
	}, 500);
})();